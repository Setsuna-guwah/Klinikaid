# Supabase Configurations (Safe to expose on client, locked by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Server-Only Configuration (CRITICAL: Never expose on client!)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenRouter Configuration (Embeddings: openai/text-embedding-ada-002)
OPENROUTER_API_KEY=your-openrouter-api-key

# Gemini API Configuration (Chatbot LLM & PDF Extraction)
GEMINI_API_KEY=your-gemini-api-key

# Resend Email Configuration (Optional, for transactional emails)
RESEND_API_KEY=your-resend-api-key

# Clinic Identity Details
NEXT_PUBLIC_CLINIC_NAME=Bloodcare Medical Laboratory
NEXT_PUBLIC_CLINIC_ADDRESS="Burgos, Rodriguez, Rizal"

# System Constants & Limits
FREE_TIER_TOKEN_LIMIT=10000000
CHAT_RATE_LIMIT_PER_HOUR=20
